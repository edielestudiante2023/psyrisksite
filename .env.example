#--------------------------------------------------------------------
# psyrisksite — Variables de entorno (plantilla)
#
# Copia este archivo a `.env` y completa los valores reales.
# Nunca subas `.env` al repositorio.
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
CI_ENVIRONMENT = development
# CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
app.baseURL = 'https://psyrisksite.cycloidtalent.com/'
# app.forceGlobalSecureRequests = true   # forzar HTTPS en producción
# app.indexPage = ''                     # quitar index.php de las URLs

#--------------------------------------------------------------------
# DATABASE — usado por /referidos y /webinar (tablas referrals, webinar_signups)
# Las migraciones SQL viven en sql/marketing/
#--------------------------------------------------------------------
database.default.hostname = localhost
database.default.database = psyrisksite
database.default.username = root
database.default.password =
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

#--------------------------------------------------------------------
# EMAIL · SENDGRID API (no SMTP)
# Patrón replicado del proyecto hermano `psyrisk` — usa el SDK HTTP v7
# con click tracking desactivado para no romper SSL en los <a href>.
# email.SMTPPass mantiene su nombre legacy pero contiene la API KEY de
# SendGrid (empieza con SG.). Si está vacía, los registros quedan en BD
# pero los emails no se envían (graceful fallback con log).
#--------------------------------------------------------------------
email.fromEmail   = 'notificacion@cycloidtalent.com'
email.fromName    = 'PsyRisk'
email.SMTPHost    = 'smtp.sendgrid.net'
email.SMTPUser    = 'apikey'
email.SMTPPass    = 'SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx'
email.SMTPPort    = 587
email.SMTPCrypto  = 'tls'
email.protocol    = 'smtp'
email.mailType    = 'html'
email.charset     = 'utf-8'

#--------------------------------------------------------------------
# WEBINAR — config opcional para la página /webinar/gracias
# Si están vacías, la página de gracias muestra "te confirmamos por email
# cuando esté disponible" en vez del botón directo.
#--------------------------------------------------------------------
WEBINAR_ZOOM_URL  = https://us02web.zoom.us/j/000000000
WEBINAR_NEXT_DATE = 'Jueves 8 de mayo de 2026, 10:00 AM (hora Colombia)'

#--------------------------------------------------------------------
# LOGGER
#--------------------------------------------------------------------
# logger.threshold = 9   # 9 = todo (debug); en producción usar 4 (warning)
